    int arr2[size2];
    printf("Enter elements of array:\n");
    for(i=0;i<size2;i++)
    {
        scanf("%d",&arr2[i]);
        

    }
    //sum of corresp. elements
    
    int sum[i];
    if (size1 != size2)
    {
        printf("The arrays should be of the same size.");
    }
    else 
    {
        for (i=0;i<size2;i++)
        {
            sum[i] = arr1[i]+arr2[i];
            
            
        }
        printf("The sum array is:\n");
        for(i=0;i<size2;i++)
        {
        
            printf("%d ",sum[i]);
        }

    }
    
