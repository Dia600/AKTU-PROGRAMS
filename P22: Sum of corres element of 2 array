    printf("Enter size of first array:");
    scanf("%d",&size1);
    int arr1[size1];
    printf("Enter elements of array:\n");
    for(i=0;i<size1;i++)
    {
        scanf("%d",&arr1[i]);
       
    }
    //array2
    printf("Enter size of second array:");
