#include <stdio.h>

int main() {
    int size,i,max=0, min=0;
    printf("Enter size of an array:");
    scanf("%d",&size);
    int arr[size];
    printf("Enter %d elements in an array:\n",size);
    for (i=0; i<size; i++)
    {
        scanf("%d",&arr[i]);
    }
   
    max = arr[0];
    
    for(i=1;i<size;i++)
    {
        if (arr[i]>max)
        {
            max = arr[i];
        }
    }
    printf("The largest element:%d\n",max);

    min = arr[0];
    for(i=1;i<size;i++)
    {
        if (arr[i]<min)
        {
            min = arr[i];
        }
    }
    printf("The smallest element:%d",min);


    return 0;
}
