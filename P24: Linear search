#include <stdio.h>

int main() {

   int size,i,flag =0,n ;
   
   printf("Enter size of array:");
   scanf("%d", &size);
   int arr[size];
   printf("Enter elements of array:\n");
   for (i=0; i<size; i++)
   {
       scanf("%d", &arr[i]);
   }
   printf("Enter the element to search:");
   scanf("%d",&n);
   for (i=0; i<size; i++)
   {
       if (arr[i]==n)
       {
           flag =1 ;
           break;
       }
   }
   if (flag==1)
   {
       printf("element %d found at index %d",n,i);
   }
   else 
   {
       printf("Element %d not found.",n);
   }
   
    return 0;
}
