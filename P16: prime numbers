#include<stdio.h>

int main()
{
    int n,i,check=1;
    printf("Enter the number you want to check:\n");
    scanf("%d",&n);
    for(i=2;i<n;i++)
    {
        check =n%i;
        if (check==0)
        {
            break;
        }
    }
    
    if (check==0)
    {
        printf("Number is not prime.");
    }
    else 
    {
        printf("Number is prime");
    }

   
    return 0;
}
